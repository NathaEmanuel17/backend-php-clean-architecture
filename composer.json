{
  "name": "natha/backend-php-clean-architecture",
  "description": "Professional PHP backend with Clean Architecture, DDD and TDD",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Nathã Emanuel Gonçalves",
      "email": "nathaemanuel.eng@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "autoload": "composer dump-autoload",
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration",
    "test:feature": "phpunit --testsuite Feature",
    "test:e2e": "phpunit --testsuite E2E",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  }
}
